---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import Faq from '../components/Faq.astro';
import Callout from '../components/Callout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SpeciesIcon from '../components/SpeciesIcon.astro';
import { SITE, SITE_URL, SPECIES, AUTHORS, YOUTUBE, type AuthorId } from '../consts';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'articles'>;
  related?: CollectionEntry<'articles'>[];
  headings?: { depth: number; slug: string; text: string }[];
}

const { entry, related = [], headings = [] } = Astro.props;
const d = entry.data;
const sp = SPECIES.find((s) => s.slug === d.species);
const author = AUTHORS[(d.author as AuthorId)] ?? AUTHORS['the-dogtor-vet'];
const url = new URL(`/articles/${entry.id}`, SITE_URL).href;
const published = d.publishedDate;
const updated = d.updatedDate ?? d.publishedDate;
const image = d.image
  ? new URL(d.image, SITE_URL).href
  : d.youtubeId
    ? `https://i.ytimg.com/vi/${d.youtubeId}/hqdefault.jpg`
    : new URL(SITE.ogImage, SITE_URL).href;

const fmt = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Section-level ToC (h2s).
const toc = headings.filter((h) => h.depth === 2);

/* ── Structured data ─────────────────────────────────────── */
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: sp?.name ?? 'Articles', item: new URL(`/species/${d.species}`, SITE_URL).href },
    { '@type': 'ListItem', position: 3, name: d.title, item: url },
  ],
};

const medicalSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalWebPage',
  '@id': url,
  url,
  name: d.title,
  headline: d.title,
  description: d.description ?? d.summary,
  inLanguage: 'en',
  image,
  datePublished: published.toISOString(),
  dateModified: updated.toISOString(),
  lastReviewed: updated.toISOString(),
  about: { '@type': 'MedicalCondition', name: d.title },
  audience: { '@type': 'MedicalAudience', audienceType: 'Pet owners and veterinary students' },
  author: { '@type': 'Organization', name: author.name, url: new URL('/about', SITE_URL).href },
  reviewedBy: { '@type': 'Organization', name: author.name, url: new URL('/about', SITE_URL).href },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', SITE_URL).href },
  },
  isPartOf: { '@type': 'WebSite', name: SITE.name, url: SITE_URL },
};

const videoSchema = d.youtubeId
  ? {
      '@context': 'https://schema.org',
      '@type': 'VideoObject',
      name: d.title,
      description: d.description ?? d.summary,
      thumbnailUrl: [`https://i.ytimg.com/vi/${d.youtubeId}/hqdefault.jpg`],
      uploadDate: published.toISOString(),
      contentUrl: `https://www.youtube.com/watch?v=${d.youtubeId}`,
      embedUrl: `https://www.youtube-nocookie.com/embed/${d.youtubeId}`,
      publisher: { '@type': 'Organization', name: SITE.name },
    }
  : null;

const faqSchema =
  d.faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: d.faq.map((f) => ({
          '@type': 'Question',
          name: f.question,
          acceptedAnswer: { '@type': 'Answer', text: f.answer.replace(/<[^>]+>/g, '') },
        })),
      }
    : null;

const jsonLd = [breadcrumbSchema, medicalSchema, videoSchema, faqSchema].filter(
  Boolean,
) as Record<string, unknown>[];
---

<BaseLayout
  title={d.title}
  description={d.description ?? d.summary}
  image={image}
  type="article"
  jsonLd={jsonLd}
>
  <article class="article">
    <div class="container prose-container">
      <Breadcrumbs
        items={[
          { label: 'Home', href: '/' },
          { label: sp?.name ?? 'Articles', href: `/species/${d.species}` },
          { label: d.title },
        ]}
      />

      <header class="article-header">
        <div class="article-tags">
          {d.emergency && <span class="pill pill-emergency">🚨 Emergency</span>}
          <span class="pill"><SpeciesIcon species={d.species} size={15} /> {sp?.name}</span>
          <span class="pill pill-muted">{d.category}</span>
        </div>
        <h1>{d.title}</h1>
        <div class="article-meta">
          <span>Reviewed by <a href="/about">{author.name}</a>, {author.credentials}</span>
          <span class="dot" aria-hidden="true">·</span>
          <span>Updated {fmt(updated)}</span>
        </div>
      </header>

      <!-- TL;DR: the block most likely to be lifted into an AI answer / snippet -->
      <div class="tldr" role="note" aria-label="Quick answer">
        <span class="tldr-label">Quick answer</span>
        <p>{d.summary}</p>
      </div>

      {d.emergency && (
        <Callout type="emergency">
          <p>
            If your pet is showing these signs right now, this may be time-critical.
            <strong> Contact your veterinarian or nearest emergency animal hospital immediately</strong> —
            don't wait to see if it passes.
          </p>
        </Callout>
      )}

      {d.youtubeId && (
        <div class="article-video">
          <VideoEmbed id={d.youtubeId} title={d.title} />
          <p class="article-video-cap">
            📺 Watch the full explainer on <a href={YOUTUBE.channelUrl} target="_blank" rel="noopener">The Dogtor</a>.
          </p>
        </div>
      )}

      {toc.length > 2 && (
        <nav class="toc" aria-label="On this page">
          <p class="toc-title">On this page</p>
          <ul>
            {toc.map((h) => (
              <li><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ul>
        </nav>
      )}

      <div class="article-body">
        <slot />
      </div>

      <Faq items={d.faq} />

      {d.references.length > 0 && (
        <section class="references" aria-labelledby="refs-heading">
          <h2 id="refs-heading">References &amp; further reading</h2>
          <ol>
            {d.references.map((ref) => (
              <li>
                {ref.url ? (
                  <a href={ref.url} target="_blank" rel="noopener nofollow">{ref.label}</a>
                ) : (
                  ref.label
                )}
              </li>
            ))}
          </ol>
        </section>
      )}

      <aside class="author-box">
        <div class="author-avatar" aria-hidden="true">🩺</div>
        <div>
          <p class="author-name">{author.name}</p>
          <p class="author-role">{author.role}</p>
          <p class="author-bio">{author.bio}</p>
        </div>
      </aside>
    </div>
  </article>

  {related.length > 0 && (
    <section class="section-sm related">
      <div class="container">
        <h2 class="related-title">Related guides</h2>
        <div class="grid grid-3">
          {related.map((r) => (
            <ArticleCard
              slug={r.id}
              title={r.data.title}
              summary={r.data.summary}
              species={r.data.species}
              category={r.data.category}
              emergency={r.data.emergency}
              youtubeId={r.data.youtubeId}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .article { padding-top: clamp(20px, 3vw, 32px); }
  .article-header { margin: 1.2rem 0 1.4rem; }
  .article-tags { display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: 1rem; }
  .article-header h1 { font-size: clamp(1.9rem, 4.5vw, 2.9rem); }
  .article-meta { margin-top: 1rem; color: var(--text-muted); font-size: .9rem; display: flex; flex-wrap: wrap; gap: .5rem; align-items: center; }
  .article-meta a { color: var(--brand-strong); }

  .tldr {
    background: var(--teal-50); border: 1px solid color-mix(in oklab, var(--brand) 22%, transparent);
    border-radius: var(--r); padding: 1.1rem 1.25rem; margin: 1.4rem 0;
  }
  .tldr-label { display: inline-block; font-size: .72rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--brand-strong); margin-bottom: .35rem; }
  .tldr p { font-size: 1.08rem; color: var(--text); margin: 0; }

  .article-video { margin: 1.8rem 0; }
  .article-video-cap { text-align: center; color: var(--text-muted); font-size: .88rem; margin-top: .7rem; }

  .toc { background: var(--surface); border: 1px solid var(--line); border-radius: var(--r); padding: 1rem 1.2rem; margin: 1.8rem 0; }
  .toc-title { font-weight: 700; font-size: .8rem; letter-spacing: .06em; text-transform: uppercase; color: var(--text-muted); margin-bottom: .5rem; }
  .toc ul { margin: 0; padding-left: 1.1rem; }
  .toc li { margin: .25rem 0; }
  .toc a { color: var(--ink-soft); text-decoration: none; }
  .toc a:hover { color: var(--brand-strong); text-decoration: underline; }

  /* Long-form typography */
  .article-body { font-size: 1.075rem; line-height: 1.75; color: var(--ink-soft); }
  .article-body :global(h2) { font-size: clamp(1.4rem, 3vw, 1.85rem); margin: 2.2rem 0 .8rem; scroll-margin-top: 90px; color: var(--text); }
  .article-body :global(h3) { font-size: 1.25rem; margin: 1.6rem 0 .6rem; scroll-margin-top: 90px; color: var(--text); }
  .article-body :global(p) { margin: 0 0 1.1rem; }
  .article-body :global(ul), .article-body :global(ol) { margin: 0 0 1.2rem; padding-left: 1.4rem; }
  .article-body :global(li) { margin: .4rem 0; }
  .article-body :global(a) { color: var(--brand-strong); font-weight: 550; }
  .article-body :global(strong) { color: var(--text); }
  .article-body :global(blockquote) { margin: 1.4rem 0; padding: .3rem 0 .3rem 1.2rem; border-left: 4px solid var(--brand); color: var(--text-muted); font-style: italic; }
  .article-body :global(table) { width: 100%; border-collapse: collapse; margin: 1.4rem 0; font-size: .97rem; display: block; overflow-x: auto; }
  .article-body :global(th), .article-body :global(td) { text-align: left; padding: .7rem .9rem; border-bottom: 1px solid var(--line); }
  .article-body :global(th) { background: var(--surface-3); font-family: var(--font-body); }
  .article-body :global(code) { background: var(--surface-3); padding: .15em .4em; border-radius: 6px; font-size: .9em; }
  .article-body :global(hr) { border: 0; border-top: 1px solid var(--line); margin: 2rem 0; }

  .references { margin: 2.5rem 0; padding-top: 1.5rem; border-top: 1px solid var(--line); }
  .references h2 { font-size: 1.3rem; margin-bottom: .8rem; }
  .references ol { padding-left: 1.3rem; color: var(--text-muted); font-size: .95rem; }
  .references li { margin: .45rem 0; }

  .author-box { display: flex; gap: 1rem; align-items: flex-start; background: var(--surface); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 1.3rem; margin: 2.5rem 0 1rem; }
  .author-avatar { font-size: 2rem; background: var(--teal-50); width: 58px; height: 58px; border-radius: 999px; display: grid; place-items: center; flex: none; }
  .author-name { font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; }
  .author-role { color: var(--brand-strong); font-size: .85rem; font-weight: 600; margin-bottom: .5rem; }
  .author-bio { color: var(--text-muted); font-size: .92rem; margin: 0; }

  .related { background: var(--surface-2); border-top: 1px solid var(--line); }
  .related-title { margin-bottom: 1.4rem; font-size: 1.6rem; }
</style>
