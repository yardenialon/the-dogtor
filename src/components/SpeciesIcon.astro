---
/**
 * Custom illustrated species icons in The Dogtor brand language
 * (rounded, friendly, teal + coral). Theme-aware via local CSS vars,
 * so the same markup adapts to light/dark and any size. No gradient IDs,
 * so it's safe to render many times per page.
 *
 * Usage:
 *   <SpeciesIcon species="dogs" size={44} chip />   // chip = soft rounded tile
 *   <SpeciesIcon species="cats" size={16} />        // inline (e.g. in a pill)
 */
interface Props {
  species?: string;
  size?: number;
  chip?: boolean;
  class?: string;
}
const { species = 'paw', size = 40, chip = false, class: cls = '' } = Astro.props;
const key = ['dogs', 'cats', 'rabbits', 'small-animals'].includes(species) ? species : 'paw';
const inner = chip ? Math.round(size * 0.7) : size;
---

<span
  class:list={['spi', { 'spi-chip': chip }, cls]}
  style={`--spi-box:${size}px`}
  aria-hidden="true"
>
  <svg viewBox="0 0 64 64" width={inner} height={inner} fill="none" xmlns="http://www.w3.org/2000/svg">
    {key === 'dogs' && (
      <>
        <path d="M17 21c-7 1-10 12-6 21 2 5 6 6 9 4 2-1 2-4 1-8-2-7-1-13 1-16 1-2-2-2-5-1Z" fill="var(--i-teal-d)"/>
        <path d="M47 21c7 1 10 12 6 21-2 5-6 6-9 4-2-1-2-4-1-8 2-7 1-13-1-16-1-2 2-2 5-1Z" fill="var(--i-teal-d)"/>
        <path d="M32 12c11 0 18 8 18 20 0 13-8 20-18 20s-18-7-18-20c0-12 7-20 18-20Z" fill="var(--i-teal)"/>
        <ellipse cx="32" cy="41" rx="12.5" ry="9.5" fill="var(--i-cream)"/>
        <circle cx="25" cy="30" r="2.7" fill="var(--i-ink)"/>
        <circle cx="39" cy="30" r="2.7" fill="var(--i-ink)"/>
        <circle cx="25.9" cy="29" r="0.9" fill="#fff"/>
        <circle cx="39.9" cy="29" r="0.9" fill="#fff"/>
        <path d="M28.5 37.5h7a2.6 2.6 0 0 1-1.3 4.5L32 44.5l-2.2-2.5a2.6 2.6 0 0 1-1.3-4.5Z" fill="var(--i-coral)"/>
        <path d="M32 44.5v3.2M32 47.7c0 1.6-2.4 1.6-2.4 0M32 47.7c0 1.6 2.4 1.6 2.4 0" stroke="var(--i-ink)" stroke-width="1.5" stroke-linecap="round"/>
      </>
    )}
    {key === 'cats' && (
      <>
        <path d="M15 14c0-2 2-3 4-2l11 8-8 10-7-4Z" fill="var(--i-teal)"/>
        <path d="M49 14c0-2-2-3-4-2l-11 8 8 10 7-4Z" fill="var(--i-teal)"/>
        <path d="M18 16l7 5-4 5-4-2Z" fill="var(--i-coral)"/>
        <path d="M46 16l-7 5 4 5 4-2Z" fill="var(--i-coral)"/>
        <path d="M32 16c11 0 17 8 17 19s-7 17-17 17-17-6-17-17S21 16 32 16Z" fill="var(--i-teal)"/>
        <path d="M22 32c0-2.4 1.6-4 3.6-4s3.6 1.6 3.6 4-1.6 4.4-3.6 4.4S22 34.4 22 32Z" fill="var(--i-ink)"/>
        <path d="M34.8 32c0-2.4 1.6-4 3.6-4s3.6 1.6 3.6 4-1.6 4.4-3.6 4.4-3.6-2-3.6-4.4Z" fill="var(--i-ink)"/>
        <circle cx="26.4" cy="30.8" r="1" fill="#fff"/>
        <circle cx="39.2" cy="30.8" r="1" fill="#fff"/>
        <path d="M29.8 40l2.2 2 2.2-2a2.2 2.2 0 0 0-4.4 0Z" fill="var(--i-coral)"/>
        <path d="M32 42v2.4M32 44.4c0 1.4-2 1.4-2 .2M32 44.4c0 1.4 2 1.4 2 .2" stroke="var(--i-ink)" stroke-width="1.4" stroke-linecap="round"/>
        <g stroke="var(--i-cream)" stroke-width="1.4" stroke-linecap="round" opacity="0.9">
          <path d="M28 41 16 39M28 43.5 17 44.5M36 41 48 39M36 43.5 47 44.5"/>
        </g>
      </>
    )}
    {key === 'rabbits' && (
      <>
        <ellipse cx="24" cy="17" rx="5.5" ry="14" fill="var(--i-teal)" transform="rotate(-9 24 17)"/>
        <ellipse cx="40" cy="17" rx="5.5" ry="14" fill="var(--i-teal)" transform="rotate(9 40 17)"/>
        <ellipse cx="24" cy="17" rx="2.4" ry="9.5" fill="var(--i-coral)" transform="rotate(-9 24 17)"/>
        <ellipse cx="40" cy="17" rx="2.4" ry="9.5" fill="var(--i-coral)" transform="rotate(9 40 17)"/>
        <ellipse cx="32" cy="40" rx="16" ry="15" fill="var(--i-teal)"/>
        <ellipse cx="32" cy="44" rx="9" ry="7" fill="var(--i-cream)"/>
        <circle cx="25" cy="38" r="2.6" fill="var(--i-ink)"/>
        <circle cx="39" cy="38" r="2.6" fill="var(--i-ink)"/>
        <circle cx="25.8" cy="37" r="0.9" fill="#fff"/>
        <circle cx="39.8" cy="37" r="0.9" fill="#fff"/>
        <path d="M30 43.5a2 2 0 0 0 4 0Z" fill="var(--i-coral)"/>
        <path d="M32 45v2.2M32 47.2c0 1.3-1.8 1.3-1.8.1M32 47.2c0 1.3 1.8 1.3 1.8.1" stroke="var(--i-ink)" stroke-width="1.3" stroke-linecap="round"/>
        <rect x="30.7" y="48.6" width="2.6" height="3.2" rx="1" fill="#fff"/>
      </>
    )}
    {key === 'small-animals' && (
      <>
        <circle cx="20" cy="23" r="6.5" fill="var(--i-teal-d)"/>
        <circle cx="44" cy="23" r="6.5" fill="var(--i-teal-d)"/>
        <circle cx="20" cy="23.5" r="2.8" fill="var(--i-coral)"/>
        <circle cx="44" cy="23.5" r="2.8" fill="var(--i-coral)"/>
        <ellipse cx="32" cy="37" rx="18" ry="16.5" fill="var(--i-teal)"/>
        <circle cx="22.5" cy="42" r="5.4" fill="var(--i-cream)"/>
        <circle cx="41.5" cy="42" r="5.4" fill="var(--i-cream)"/>
        <circle cx="26" cy="35" r="2.8" fill="var(--i-ink)"/>
        <circle cx="38" cy="35" r="2.8" fill="var(--i-ink)"/>
        <circle cx="26.9" cy="34" r="1" fill="#fff"/>
        <circle cx="38.9" cy="34" r="1" fill="#fff"/>
        <path d="M30 40.2h4a1.8 1.8 0 0 1-2 1.8 1.8 1.8 0 0 1-2-1.8Z" fill="var(--i-coral)"/>
        <path d="M32 42v2M32 44c0 1.2-1.7 1.2-1.7.1M32 44c0 1.2 1.7 1.2 1.7.1" stroke="var(--i-ink)" stroke-width="1.3" stroke-linecap="round"/>
        <rect x="30.9" y="44.8" width="2.2" height="2.6" rx="0.7" fill="#fff"/>
      </>
    )}
    {key === 'paw' && (
      <>
        <ellipse cx="32" cy="41" rx="12" ry="10" fill="var(--i-teal)"/>
        <ellipse cx="18.5" cy="30" rx="4.6" ry="6" fill="var(--i-teal)"/>
        <ellipse cx="45.5" cy="30" rx="4.6" ry="6" fill="var(--i-teal)"/>
        <ellipse cx="26" cy="21.5" rx="4.4" ry="5.6" fill="var(--i-coral)"/>
        <ellipse cx="38" cy="21.5" rx="4.4" ry="5.6" fill="var(--i-coral)"/>
      </>
    )}
  </svg>
</span>

<style>
  .spi {
    /* icon palette — kept separate from global text vars so eyes never
       invert in dark mode. Slightly brighter teal in dark for contrast. */
    --i-teal: var(--teal-600);
    --i-teal-d: var(--teal-700);
    --i-coral: var(--coral-500);
    --i-ink: #063b36;
    --i-cream: #f4fbf9;
    display: inline-grid;
    place-items: center;
    line-height: 0;
    vertical-align: middle;
  }
  .spi svg { display: block; }
  .spi-chip {
    width: var(--spi-box);
    height: var(--spi-box);
    border-radius: 28%;
    background: linear-gradient(150deg, var(--teal-50), var(--teal-100));
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--brand) 12%, transparent);
  }
  @media (prefers-color-scheme: dark) {
    .spi { --i-teal: #19bda8; --i-teal-d: #0e9f8e; }
  }
  :root[data-theme='dark'] .spi { --i-teal: #19bda8; --i-teal-d: #0e9f8e; }
  :root[data-theme='light'] .spi { --i-teal: var(--teal-600); --i-teal-d: var(--teal-700); }
</style>
