---
interface Props {
  type?: 'emergency' | 'warning' | 'tip' | 'info';
  title?: string;
}
const { type = 'info', title } = Astro.props;
const icons = { emergency: '🚨', warning: '⚠️', tip: '💡', info: 'ℹ️' } as const;
const defaultTitles = {
  emergency: 'This is an emergency',
  warning: 'Important',
  tip: 'Vet tip',
  info: 'Good to know',
} as const;
---

<aside class:list={['callout', `callout-${type}`]} role={type === 'emergency' ? 'alert' : 'note'}>
  <div class="callout-head">
    <span class="callout-icon" aria-hidden="true">{icons[type]}</span>
    <strong>{title ?? defaultTitles[type]}</strong>
  </div>
  <div class="callout-body"><slot /></div>
</aside>

<style>
  .callout {
    border-radius: var(--r); padding: 1rem 1.15rem; margin: 1.6rem 0;
    border: 1px solid var(--line-2); background: var(--surface-3);
    border-left: 4px solid var(--brand);
  }
  .callout-head { display: flex; align-items: center; gap: .5rem; font-family: var(--font-display); font-size: 1.02rem; }
  .callout-body { margin-top: .4rem; color: var(--ink-soft); }
  .callout-body :global(p) { margin: .4rem 0 0; }
  .callout-body :global(p:first-child) { margin-top: 0; }
  .callout-emergency { background: var(--red-100); border-left-color: var(--red-600); border-color: color-mix(in oklab, var(--red-600) 30%, transparent); }
  .callout-emergency .callout-head { color: var(--red-600); }
  .callout-warning { background: var(--amber-100); border-left-color: var(--amber-500); }
  .callout-tip { background: var(--teal-50); border-left-color: var(--brand); }
</style>
