---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { SITE, SITE_URL, SPECIES, YOUTUBE } from '../consts';

const all = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
);
const featured = all.filter((a) => a.data.featured).slice(0, 3);
const latest = all.slice(0, 6);
const emergencies = all.filter((a) => a.data.emergency).slice(0, 3);

// WebSite schema with sitelinks search box hint.
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE_URL,
  description: SITE.shortDescription,
  inLanguage: 'en',
  publisher: { '@type': 'Organization', name: SITE.name },
};
---

<BaseLayout title={`${SITE.name} — ${SITE.tagline}`} fullTitle={`The Dogtor — Veterinary Education for Pet Owners`} jsonLd={websiteSchema}>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-copy">
        <span class="eyebrow">Vet-reviewed pet health</span>
        <h1>{SITE.hero}</h1>
        <p class="lede">
          Clear, evidence-based guides on the diseases, warning signs and emergencies that matter —
          for dogs, cats, rabbits and small animals. Written by certified veterinarians.
        </p>
        <div class="hero-actions">
          <a href="/articles" class="btn btn-primary btn-lg">Browse guides</a>
          <a href={YOUTUBE.subscribeUrl} class="btn btn-yt btn-lg" target="_blank" rel="noopener">▶ Watch on YouTube</a>
        </div>
        <ul class="hero-trust">
          <li>✔ Written &amp; reviewed by DVMs</li>
          <li>✔ Grounded in clinical evidence</li>
          <li>✔ Know when to call the vet</li>
        </ul>
      </div>
      <div class="hero-art" aria-hidden="true">
        <div class="hero-orb"></div>
        <div class="hero-card hero-card-1">🐕 Bloat (GDV)</div>
        <div class="hero-card hero-card-2">🐈 Not eating?</div>
        <div class="hero-card hero-card-3">🩺 When to worry</div>
        <div class="hero-emoji">🐾</div>
      </div>
    </div>
  </section>

  <!-- SPECIES PILLARS -->
  <section class="section-sm">
    <div class="container">
      <div class="grid grid-4">
        {SPECIES.map((s) => (
          <a href={`/species/${s.slug}`} class="card card-link species-tile">
            <span class="species-emoji" aria-hidden="true">{s.emoji}</span>
            <span class="species-name">{s.name}</span>
            <span class="species-blurb">{s.blurb}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- EMERGENCY STRIP -->
  {emergencies.length > 0 && (
    <section class="section-sm">
      <div class="container">
        <div class="emergency-banner">
          <div class="emergency-banner-copy">
            <span class="pill pill-emergency">🚨 Emergencies</span>
            <h2>Would you recognise a pet emergency?</h2>
            <p>Bloat, poisoning, IMHA and urinary blockages can turn fatal within hours. Learn the red flags.</p>
            <a href="/emergencies" class="btn btn-ghost">See the emergency guide →</a>
          </div>
          <div class="emergency-banner-list">
            {emergencies.map((a) => (
              <a href={`/articles/${a.id}`} class="emergency-link">
                <span aria-hidden="true">→</span> {a.data.title}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- LATEST ARTICLES -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Latest guides</span>
          <h2>Fresh from the clinic</h2>
        </div>
        <a href="/articles" class="btn btn-ghost">All articles →</a>
      </div>
      {latest.length > 0 ? (
        <div class="grid grid-3">
          {latest.map((a) => (
            <ArticleCard
              slug={a.id}
              title={a.data.title}
              summary={a.data.summary}
              species={a.data.species}
              category={a.data.category}
              emergency={a.data.emergency}
              youtubeId={a.data.youtubeId}
            />
          ))}
        </div>
      ) : (
        <p class="empty">Articles are on the way — check back soon.</p>
      )}
    </div>
  </section>

  <!-- CHANNEL CTA -->
  <section class="section-sm">
    <div class="container">
      <div class="channel-cta">
        <div>
          <h2>Prefer to watch?</h2>
          <p>Every guide here has a companion video. Subscribe to The Dogtor for visual, easy-to-follow explanations of real clinical cases.</p>
        </div>
        <a href={YOUTUBE.subscribeUrl} class="btn btn-yt btn-lg" target="_blank" rel="noopener">▶ Subscribe on YouTube</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero { padding: clamp(36px, 6vw, 80px) 0 clamp(24px, 4vw, 40px); overflow: hidden; }
  .hero-inner { display: grid; grid-template-columns: 1.15fr .85fr; gap: clamp(24px, 5vw, 60px); align-items: center; }
  .hero-copy h1 { font-size: clamp(2.1rem, 5.2vw, 3.6rem); margin: .6rem 0 1rem; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: .7rem; margin: 1.6rem 0 1.4rem; }
  .hero-trust { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: .4rem 1.3rem; color: var(--text-muted); font-size: .92rem; font-weight: 500; }

  .hero-art { position: relative; min-height: 320px; display: grid; place-items: center; }
  .hero-orb { position: absolute; width: 320px; height: 320px; border-radius: 999px; background: radial-gradient(circle at 40% 35%, var(--teal-500), var(--teal-700)); filter: blur(4px); opacity: .9; box-shadow: var(--shadow-lg); }
  .hero-emoji { position: relative; font-size: 8rem; filter: drop-shadow(0 8px 20px rgba(0,0,0,.25)); }
  .hero-card { position: absolute; background: var(--surface); border: 1px solid var(--line); border-radius: 14px; padding: .5rem .8rem; font-size: .85rem; font-weight: 600; box-shadow: var(--shadow-lg); }
  .hero-card-1 { top: 6%; left: -2%; animation: float 6s ease-in-out infinite; }
  .hero-card-2 { top: 40%; right: -4%; animation: float 7s ease-in-out infinite .5s; }
  .hero-card-3 { bottom: 6%; left: 8%; animation: float 6.5s ease-in-out infinite 1s; }
  @keyframes float { 0%,100% { transform: translateY(0) } 50% { transform: translateY(-10px) } }
  @media (max-width: 820px) { .hero-inner { grid-template-columns: 1fr; } .hero-art { display: none; } }

  /* Species tiles */
  .species-tile { display: flex; flex-direction: column; gap: .5rem; padding: 1.3rem; text-decoration: none; color: inherit; }
  .species-emoji { font-size: 2.2rem; }
  .species-name { font-family: var(--font-display); font-weight: 600; font-size: 1.2rem; }
  .species-blurb { color: var(--text-muted); font-size: .88rem; line-height: 1.5; }

  /* Emergency banner */
  .emergency-banner { display: grid; grid-template-columns: 1.2fr 1fr; gap: 1.5rem; align-items: center; background: linear-gradient(135deg, var(--red-100), var(--surface)); border: 1px solid color-mix(in oklab, var(--red-600) 20%, transparent); border-radius: var(--r-xl); padding: clamp(1.4rem, 3vw, 2.2rem); }
  .emergency-banner h2 { margin: .7rem 0 .5rem; font-size: clamp(1.35rem, 3vw, 1.8rem); }
  .emergency-banner p { color: var(--ink-soft); margin-bottom: 1.1rem; }
  .emergency-banner-list { display: flex; flex-direction: column; gap: .6rem; }
  .emergency-link { background: var(--surface); border: 1px solid var(--line); border-radius: var(--r); padding: .75rem 1rem; text-decoration: none; color: var(--text); font-weight: 550; font-size: .95rem; transition: transform .15s, border-color .2s; }
  .emergency-link:hover { transform: translateX(4px); border-color: var(--red-600); color: var(--red-600); }
  @media (max-width: 720px) { .emergency-banner { grid-template-columns: 1fr; } }

  /* Section heads */
  .section-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; margin-bottom: 1.8rem; flex-wrap: wrap; }
  .section-head h2 { font-size: clamp(1.6rem, 3.5vw, 2.2rem); margin-top: .3rem; }
  .empty { color: var(--text-muted); }

  /* Channel CTA */
  .channel-cta { display: flex; flex-wrap: wrap; gap: 1.2rem; align-items: center; justify-content: space-between; background: var(--teal-900); color: #eafaf7; border-radius: var(--r-xl); padding: clamp(1.6rem, 4vw, 2.6rem); }
  .channel-cta h2 { color: #fff; font-size: clamp(1.5rem, 3vw, 2rem); }
  .channel-cta p { color: #bfe6df; margin-top: .4rem; max-width: 52ch; }
</style>
